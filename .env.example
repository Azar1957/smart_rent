# Пример конфигурации для docker compose.
# В dev-режиме файл можно не создавать — всё поднимется с дефолтами.
# В prod-режиме setup-server.sh автоматически сгенерирует /srv/smartrent/.env
# со случайным IRIS_PASSWORD при первом запуске.
#
# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Пароль _SYSTEM в IRIS (используется как начальный).
# Требования: 8+ символов, буквы+цифры, без $ и обратных слэшей.
# ---------------------------------------------------------------------------
IRIS_PASSWORD=SYS1

# ---------------------------------------------------------------------------
# Привязка портов iris/frontend в docker-compose.yml.
#   0.0.0.0 — доступ наружу (dev)
#   127.0.0.1 — только loopback, наружу выходим через nginx (prod)
# ---------------------------------------------------------------------------
BIND=0.0.0.0

# ---------------------------------------------------------------------------
# Домен и email для Let's Encrypt (используются deploy/issue-cert.sh и nginx).
# Если домена нет — оставьте APP_DOMAIN=IP, сайт будет работать по http://<IP>/
# ---------------------------------------------------------------------------
APP_DOMAIN=IP
APP_LETSENCRYPT_EMAIL=
