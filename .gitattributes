# Запретить Git конвертировать концы строк для shell-скриптов и
# файлов InterSystems IRIS (.cls). Иначе при checkout на Windows
# с autocrlf=true файлы получают CRLF и shell в Linux-контейнере
# не может выполнить "#!/bin/bash\r".
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.cls   text eol=lf
*.script text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
